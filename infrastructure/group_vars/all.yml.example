pnpu_app_name: portal
pnpu_service_name: pnpu-portal
pnpu_service_user: pnpu
pnpu_service_group: pnpu
pnpu_base_dir: /opt/pnpu/portal
pnpu_env_dir: /etc/pnpu
pnpu_env_file: /etc/pnpu/portal.env
pnpu_node_bin: /usr/bin/npm
pnpu_node_env: production
pnpu_port: 3000
pnpu_health_live_url: http://127.0.0.1:3000/health/live
pnpu_health_ready_url: http://127.0.0.1:3000/health/ready
pnpu_health_timeout: 5
pnpu_release_version: 0.1.0
pnpu_previous_release_version: 0.1.0
pnpu_release_artifact_local_path: artifacts/pnpu-portal-0.1.0.tar.gz
pnpu_release_checksum_local_path: artifacts/pnpu-portal-0.1.0.tar.gz.sha256
pnpu_public_base_url: http://127.0.0.1:3000
pnpu_commit_sha: unknown
pnpu_log_level: info
pnpu_enable_request_logs: "true"
pnpu_catalog_repository: in-memory
pnpu_omeka_base_url: ""
pnpu_omeka_timeout_ms: 2000
pnpu_omeka_page_size: 100
pnpu_omeka_max_pages: 100
pnpu_omeka_cache_ttl_seconds: 60
pnpu_omeka_require_approved_mapping: "false"
pnpu_catalog_refresh_token: ""
pnpu_admin_auth_mode: token
pnpu_admin_required_role: pnpu-admin
pnpu_admin_import_read_role: pnpu-import-reader
pnpu_admin_import_write_role: pnpu-import-writer
pnpu_admin_import_rollback_role: pnpu-import-rollback
pnpu_oidc_issuer: ""
pnpu_oidc_audience: ""
pnpu_oidc_client_id: ""
pnpu_oidc_client_secret: ""
pnpu_oidc_scopes: openid profile email
