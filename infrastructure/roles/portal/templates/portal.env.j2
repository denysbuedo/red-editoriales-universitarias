NODE_ENV={{ pnpu_node_env }}
PORT={{ pnpu_port }}
PNPU_PUBLIC_BASE_URL={{ pnpu_public_base_url | default('http://127.0.0.1:' ~ pnpu_port) }}
PNPU_COMMIT_SHA={{ pnpu_commit_sha | default('unknown') }}
PNPU_LOG_LEVEL={{ pnpu_log_level | default('info') }}
PNPU_ENABLE_REQUEST_LOGS={{ pnpu_enable_request_logs | default('true') }}
PNPU_CATALOG_REPOSITORY={{ pnpu_catalog_repository | default('in-memory') }}
PNPU_OMEKA_BASE_URL={{ pnpu_omeka_base_url | default('') }}
PNPU_OMEKA_TIMEOUT_MS={{ pnpu_omeka_timeout_ms | default(2000) }}
PNPU_OMEKA_PAGE_SIZE={{ pnpu_omeka_page_size | default(100) }}
PNPU_OMEKA_MAX_PAGES={{ pnpu_omeka_max_pages | default(100) }}
PNPU_OMEKA_CACHE_TTL_SECONDS={{ pnpu_omeka_cache_ttl_seconds | default(60) }}
PNPU_OMEKA_REQUIRE_APPROVED_MAPPING={{ pnpu_omeka_require_approved_mapping | default('false') }}
PNPU_CATALOG_REFRESH_TOKEN={{ pnpu_catalog_refresh_token | default('') }}
PNPU_ADMIN_AUTH_MODE={{ pnpu_admin_auth_mode | default('token') }}
PNPU_ADMIN_REQUIRED_ROLE={{ pnpu_admin_required_role | default('pnpu-admin') }}
PNPU_OIDC_ISSUER={{ pnpu_oidc_issuer | default('') }}
PNPU_OIDC_AUDIENCE={{ pnpu_oidc_audience | default('') }}
PNPU_OIDC_CLIENT_ID={{ pnpu_oidc_client_id | default('') }}
PNPU_OIDC_CLIENT_SECRET={{ pnpu_oidc_client_secret | default('') }}
PNPU_OIDC_SCOPES={{ pnpu_oidc_scopes | default('openid profile email') }}
