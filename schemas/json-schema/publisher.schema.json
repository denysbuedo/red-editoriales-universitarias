{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pnpu.mes.gob.cu/schemas/json-schema/publisher.schema.json",
  "title": "PNPU Publisher",
  "description": "Perfil de aplicacion PNPU para editoriales universitarias. Reutiliza Schema.org Organization y Dublin Core Terms.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "identifier",
    "officialName",
    "university",
    "country"
  ],
  "properties": {
    "@context": {
      "description": "Contexto JSON-LD que define los namespaces y el mapeo semantico de las propiedades.",
      "type": [
        "string",
        "object",
        "array"
      ],
      "default": "https://pnpu.mes.gob.cu/schemas/jsonld-context/context.jsonld"
    },
    "@id": {
      "description": "URI publica persistente de la editorial.",
      "type": "string",
      "format": "uri"
    },
    "@type": {
      "description": "Tipo RDF/Schema.org de la editorial.",
      "type": "string",
      "enum": [
        "Organization",
        "schema:Organization"
      ],
      "default": "Organization"
    },
    "identifier": {
      "description": "Identificador principal PNPU de la editorial expresado como UUID v7.",
      "$ref": "#/$defs/uuidV7"
    },
    "officialName": {
      "description": "Nombre oficial de la editorial universitaria.",
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "acronym": {
      "description": "Sigla o nombre abreviado de la editorial.",
      "type": "string",
      "minLength": 1,
      "maxLength": 60
    },
    "publisherCode": {
      "description": "Codigo institucional de la editorial en el registro oficial RNEU o PNPU. Extension PNPU.",
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "description": {
      "description": "Descripcion institucional de la editorial.",
      "type": "string",
      "maxLength": 5000
    },
    "university": {
      "description": "Universidad a la que pertenece la editorial.",
      "oneOf": [
        {
          "$ref": "#/$defs/entityReference"
        },
        {
          "$ref": "university.schema.json"
        }
      ]
    },
    "province": {
      "description": "Provincia o subdivision administrativa principal.",
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "country": {
      "description": "Pais de la editorial, codificado segun ISO 3166-1 alfa-2.",
      "$ref": "#/$defs/countryCode"
    },
    "website": {
      "description": "Sitio web oficial de la editorial.",
      "type": "string",
      "format": "uri"
    },
    "logo": {
      "description": "URL publica del logotipo institucional de la editorial.",
      "type": "string",
      "format": "uri"
    },
    "contactPoint": {
      "description": "Datos de contacto publico de la editorial.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "email": {
          "description": "Correo de contacto.",
          "type": "string",
          "format": "email"
        },
        "telephone": {
          "description": "Telefono de contacto en formato legible internacional.",
          "type": "string",
          "minLength": 3,
          "maxLength": 50
        },
        "url": {
          "description": "URL de contacto o pagina institucional.",
          "type": "string",
          "format": "uri"
        }
      }
    },
    "sameAs": {
      "description": "URIs equivalentes en autoridades externas o sitios institucionales.",
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "format": "uri"
      }
    }
  },
  "$defs": {
    "uuidV7": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-7[0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$"
    },
    "countryCode": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "entityReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identifier",
        "name"
      ],
      "properties": {
        "identifier": {
          "description": "UUID v7 de la entidad referenciada.",
          "$ref": "#/$defs/uuidV7"
        },
        "@id": {
          "description": "URI publica de la entidad referenciada.",
          "type": "string",
          "format": "uri"
        },
        "name": {
          "description": "Etiqueta legible de la entidad referenciada.",
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "examples": [
    {
      "@context": "https://pnpu.mes.gob.cu/schemas/jsonld-context/context.jsonld",
      "@type": "Organization",
      "@id": "https://pnpu.mes.gob.cu/editoriales/018f6e2d-7b58-7d61-9b7d-1f4c2f9a1c03",
      "identifier": "018f6e2d-7b58-7d61-9b7d-1f4c2f9a1c03",
      "officialName": "Editorial Universidad de La Habana",
      "acronym": "Editorial UH",
      "publisherCode": "RNEU-UH",
      "university": {
        "identifier": "018f6e2d-7b58-7d61-9b7d-1f4c2f9a1c02",
        "@id": "https://pnpu.mes.gob.cu/universidades/018f6e2d-7b58-7d61-9b7d-1f4c2f9a1c02",
        "name": "Universidad de La Habana"
      },
      "province": "La Habana",
      "country": "CU",
      "website": "https://www.uh.cu/editorial"
    }
  ]
}
